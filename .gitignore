# ========================================
# Node.js & Package Management
# ========================================
node_modules/
frontend/node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.pnpm-debug.log*

# ========================================
# Environment & Configuration
# ========================================
# NEVER commit .env files with secrets
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.*.example
!.env.example
!backend/.env.example
!frontend/.env.example

# ========================================
# Build Outputs & Distribution
# ========================================
# Frontend builds
frontend/dist/
frontend/build/
frontend/.vite/

# Backend builds (if TypeScript)
backend/dist/
backend/build/
backend/lib/

# Other build artifacts
*.tgz
*.tar.gz
.next/
out/

