# ==========================================
# Bytelink Frontend Environment Configuration
# ==========================================
# Copy this file to .env and fill in actual values

# ==========================================
# API Configuration
# ==========================================
# Backend API Base URL
# Development: http://localhost:4000/api
# Production: https://api.yourdomain.com/api or https://yourdomain.com/api
VITE_API_BASE_URL=http://localhost:4000/api

# ==========================================
# Application Configuration
# ==========================================
# Application name displayed in UI
VITE_APP_NAME=Bytelink

# Application version
VITE_APP_VERSION=1.0.0

# ==========================================
# Feature Flags (Optional)
# ==========================================
# Enable analytics visualization (default: true)
VITE_ENABLE_ANALYTICS=true

# Enable QR code generation (default: true)
VITE_ENABLE_QR_CODE=true

# Enable public stats (default: true)
VITE_ENABLE_PUBLIC_STATS=true

# ==========================================
# Sentry Error Tracking (Optional)
# ==========================================
# Sentry DSN for error tracking in production
# Get from: https://sentry.io
# Leave empty to disable
VITE_SENTRY_DSN=
