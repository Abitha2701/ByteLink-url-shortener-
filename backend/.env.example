# ==========================================
# Bytelink Backend Environment Configuration
# ==========================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!
# The .env file is automatically excluded in .gitignore

# ==========================================
# Database Configuration
# ==========================================
# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# How to get your connection string:
#   1. Go to MongoDB Atlas: https://account.mongodb.com/account/login
#   2. Navigate to: Clusters > Connect > Drivers
#   3. Copy the connection string and replace username/password
# Both MONGO_URI and MONGODB_URI are supported
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/bytelink?retryWrites=true&w=majority

# ==========================================
# Authentication & Security
# ==========================================
# JWT Secret Key (MUST be at least 32 characters in production!)
# Generate a secure key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or use an online generator: https://generate-secret.vercel.app/
# Change this immediately in production to a unique, random string
JWT_SECRET=jyMVslQU971HtEifqO8C9o9L9SgfB3UNh9JGmC5mhd8

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list of allowed origins
# Local development: http://localhost:5173,http://localhost:3000
# Production: https://yourdomain.com,https://www.yourdomain.com,https://app.yourdomain.com
# For security, never use wildcard (*) in production
CORS_ORIGIN=http://localhost:5173

# ==========================================
# Server Configuration
# ==========================================
# Server listening port (default: 4000)
# Make sure this port is not blocked by firewall
PORT=4000

# Node.js environment
# Options: development, production, staging
# Use 'production' for deployment to add optimizations
NODE_ENV=development

# ==========================================
# Base URL Configuration
# ==========================================
# Used for constructing short URLs in responses
# Development: http://localhost:4000
# Production: https://yourdomain.com or https://short.yourdomain.com
BASE_URL=http://localhost:4000

# ==========================================
# Logging Configuration (Optional)
# ==========================================
# Log level (error, warn, info, debug)
# debug: Most verbose, includes all information
# info: Standard production level
# warn: Only warnings and errors
# error: Only errors
LOG_LEVEL=info

# ==========================================
# API Rate Limiting Configuration (Optional)
# ==========================================
# Global rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Global rate limit max requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# Auth endpoint rate limit max attempts (default: 5)
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# ==========================================
# Advanced Configuration (Optional)
# ==========================================
# Enable/disable analytics collection (default: true)
ENABLE_ANALYTICS=true

# Enable/disable visitor geo-tracking (default: true)
ENABLE_GEO_TRACKING=true

# Database connection timeout in milliseconds (default: 5000)
DB_CONNECTION_TIMEOUT=5000

